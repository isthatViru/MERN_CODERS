<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Home</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<!-- NAVBAR -->
<nav class="bg-gray-900 text-white px-8 py-4 flex justify-between items-center">
<h1 class="text-xl font-bold">MyStore</h1>

<a href="/admin" class="bg-yellow-400 text-black px-4 py-2 rounded hover:bg-yellow-500">
Admin Panel
</a>
</nav>


<!-- CAROUSEL -->
<div class="relative overflow-hidden mt-6">

<div id="slider" class="flex transition-transform duration-500">

<% data.forEach(data => { %>


<div class="min-w-full h-[400px]">
<img src="/uploads/<%= data.img %>" class="w-full h-full object-cover">
</div>
 
<% }) %>

</div>


<!-- LEFT BUTTON -->
<button onclick="prevSlide()"
class="absolute left-5 top-1/2 -translate-y-1/2 bg-white p-3 rounded-full shadow">
❮
</button>

<!-- RIGHT BUTTON -->
<button onclick="nextSlide()"
class="absolute right-5 top-1/2 -translate-y-1/2 bg-white p-3 rounded-full shadow">
❯
</button>

</div> <!-- CAROUSEL CLOSED HERE -->


<!-- data GRID -->
<div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 px-6 py-16">

<% data.forEach(items => { %>

<div class="bg-white rounded-xl shadow hover:shadow-lg transition overflow-hidden">

<img src="/uploads/<%= items.img %>" 
class="w-full h-48 object-cover">

<div class="p-4">

<h2 class="text-lg font-bold">
<%= items.name %>
</h2>

<p class="text-gray-600 text-sm mt-2">
<%= items.text %>
</p>

<p class="text-xs text-gray-400 mt-2">
ID : <%= items.id %>
</p>

<div class="flex gap-3 mt-4">

<a href="/edit/<%= items._id %>" 
class="flex-1 text-center bg-blue-600 text-white py-2 rounded hover:bg-blue-700">
Edit
</a>

<a href="/delete/<%= items._id %>" 
class="flex-1 text-center bg-red-500 text-white py-2 rounded hover:bg-red-600">
Delete
</a>

</div>

</div>

</div>

<% }) %>

</div>



<script>

let slider = document.getElementById("slider")
let index = 0

function nextSlide(){
index++

if(index >= slider.children.length){
index = 0
}

slider.style.transform = `translateX(-${index*100}%)`
}

function prevSlide(){
index--

if(index < 0){
index = slider.children.length - 1
}

slider.style.transform = `translateX(-${index*100}%)`
}

setInterval(nextSlide,4000)

</script>


</body>
</html>