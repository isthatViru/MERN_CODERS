<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Error</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:"Segoe UI",sans-serif;
}

body{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#ff6a6a,#b31217);
overflow:hidden;
}

/* floating background circles */

.circle{
position:absolute;
border-radius:50%;
background:rgba(255,255,255,0.08);
animation:float 12s infinite linear;
}

.circle:nth-child(1){
width:220px;
height:220px;
top:12%;
left:12%;
}

.circle:nth-child(2){
width:300px;
height:300px;
bottom:12%;
right:12%;
animation-duration:15s;
}

@keyframes float{
0%{transform:translateY(0)}
50%{transform:translateY(-40px)}
100%{transform:translateY(0)}
}

/* card */

.container{
background:rgba(255,255,255,0.15);
backdrop-filter:blur(15px);
padding:50px 60px;
border-radius:15px;
text-align:center;
color:white;
box-shadow:0 15px 40px rgba(0,0,0,0.3);
animation:fadeIn 1s ease;
}

/* error cross animation */

.cross{
width:80px;
height:80px;
border-radius:50%;
background:#e53935;
display:flex;
align-items:center;
justify-content:center;
margin:0 auto 20px;
animation:pop 0.6s ease;
}

.cross::after{
content:"✖";
font-size:40px;
color:white;
}

@keyframes pop{
0%{transform:scale(0)}
80%{transform:scale(1.2)}
100%{transform:scale(1)}
}

h1{
font-size:28px;
margin-bottom:10px;
}

p{
opacity:0.9;
margin-bottom:25px;
}

a{
text-decoration:none;
padding:10px 25px;
border-radius:6px;
background:linear-gradient(135deg,#ff4e50,#f00000);
color:white;
font-weight:600;
transition:0.3s;
}

a:hover{
transform:scale(1.08);
}

@keyframes fadeIn{
from{
opacity:0;
transform:translateY(30px);
}
to{
opacity:1;
transform:translateY(0);
}
}

</style>
</head>

<body>

<div class="circle"></div>
<div class="circle"></div>

<div class="container">

<div class="cross"></div>

<h1>Registration Failed ❌</h1>

<p>Something went wrong while creating your account.</p>

<a href="/">Try Again</a>

</div>

</body>
</html>