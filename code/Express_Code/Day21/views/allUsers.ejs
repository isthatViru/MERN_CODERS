<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>All Users</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gray-100 min-h-screen">

<!-- Header -->
<div class="bg-blue-700 text-white py-4 shadow-md">
<div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
<h1 class="text-2xl font-bold">Users</h1>
<a href="/" class="bg-white text-blue-700 px-4 py-2 rounded-lg font-semibold">
Home
</a>
</div>
</div>


<!-- Users Grid -->
<div class="max-w-7xl mx-auto p-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

<% users.forEach(user => { %>

<div class="bg-white rounded-xl shadow-md hover:shadow-xl transition p-5">

<!-- Profile -->
<div class="flex flex-col items-center">

<img 
src="/uploads/<%= user.profile %>" 
alt="<%= user.userName %>"
class="w-24 h-24 rounded-full object-cover border-4 border-blue-500"
/>

<h2 class="mt-3 text-lg font-semibold text-gray-800">
<%= user.userName %>
</h2>

<p class="text-sm text-gray-500">
<%= user.email %>
</p>

<p class="text-sm text-gray-500">
<%= user.phone %>
</p>

</div>

<!-- Button -->
<div class="mt-4 text-center">
<a 
href="/user/<%= user._id %>"
class="bg-blue-600 text-white px-4 py-2 rounded-full text-sm hover:bg-blue-700"
>
View Profile
</a>
<a 
href="/delete/<%= user._id %>"
class="bg-blue-600 text-white px-4 py-2 rounded-full text-sm hover:bg-blue-700"
>
Delete
</a>
</div>

</div>

<% }) %>

</div>

</body>
</html>