<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Sign up • Instagram</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-[#fafafa] flex flex-col items-center justify-center min-h-screen font-sans">

<!-- SIGNUP CARD -->
<div class="bg-white border border-gray-300 w-[350px] p-8 text-center">

<h1 class="text-4xl font-semibold mb-4" style="font-family: 'Billabong', cursive;">
Instagram
</h1>

<p class="text-gray-500 text-sm font-semibold mb-4">
Sign up to see photos and videos from your friends.
</p>

<!-- FACEBOOK BUTTON -->
<button class="bg-[#0095f6] text-white w-full py-2 rounded text-sm font-semibold">
Log in with Facebook
</button>

<!-- DIVIDER -->
<div class="flex items-center my-4">
<div class="flex-grow border-t"></div>
<span class="mx-3 text-gray-400 text-sm font-semibold">OR</span>
<div class="flex-grow border-t"></div>
</div>

<form
id="signupForm"
action="/signup"
method="POST"
enctype="multipart/form-data"
class="space-y-2"
>

<!-- PHONE -->
<input
type="tel"
id="phone"
name="phone"
placeholder="Mobile Number"
required
pattern="[0-9]{10}"
class="w-full border border-gray-300 bg-[#fafafa] px-3 py-2 text-sm rounded"
/>

<!-- EMAIL -->
<input
type="email"
id="email"
name="email"
placeholder="Email"
required
class="w-full border border-gray-300 bg-[#fafafa] px-3 py-2 text-sm rounded"
/>

<!-- FULL NAME -->
<input
type="text"
id="userName"
name="userName"
placeholder="Username"
required
minlength="3"
maxlength="20"
class="w-full border border-gray-300 bg-[#fafafa] px-3 py-2 text-sm rounded"
/>

<!-- PASSWORD -->
<input
type="password"
id="password"
name="password"
placeholder="Password"
required
minlength="6"
class="w-full border border-gray-300 bg-[#fafafa] px-3 py-2 text-sm rounded"
/>

<!-- PROFILE IMAGE -->
<input
type="file"
id="profile"
name="profile"
accept="image/*"
required
class="w-full border border-gray-300 bg-[#fafafa] px-3 py-2 text-sm rounded"
/>

<!-- PREVIEW -->
<img
id="preview"
class="hidden w-16 h-16 rounded-full mx-auto mt-2 object-cover"
/>

<p id="errorMsg" class="text-red-500 text-xs hidden"></p>

<!-- TERMS -->
<p class="text-xs text-gray-400 mt-3 px-2">
People who use our service may have uploaded your contact information to Instagram.
</p>

<p class="text-xs text-gray-400 mt-2 px-2">
By signing up, you agree to our
<b>Terms</b>,
<b>Privacy Policy</b>
and
<b>Cookies Policy</b>.
</p>

<!-- SUBMIT -->
<button
type="submit"
class="bg-[#0095f6] text-white w-full py-2 rounded text-sm font-semibold mt-3"
>
Sign Up
</button>

</form>

</div>

<!-- LOGIN BOX -->
<div class="bg-white border border-gray-300 w-[350px] text-center py-4 mt-3 text-sm">

Have an account?
<a href="/login" class="text-[#0095f6] font-semibold">
Log in
</a>

</div>

<script>

const form = document.getElementById("signupForm")
const errorMsg = document.getElementById("errorMsg")
const profileInput = document.getElementById("profile")
const preview = document.getElementById("preview")

profileInput.addEventListener("change",function(){

const file = this.files[0]

if(file){
preview.src = URL.createObjectURL(file)
preview.classList.remove("hidden")
}

})

form.addEventListener("submit",function(e){

const username = document.getElementById("userName").value.trim()
const password = document.getElementById("password").value
const phone = document.getElementById("phone").value

if(username.length < 3){
e.preventDefault()
errorMsg.textContent="Username must be at least 3 characters"
errorMsg.classList.remove("hidden")
return
}

if(password.length < 6){
e.preventDefault()
errorMsg.textContent="Password must be at least 6 characters"
errorMsg.classList.remove("hidden")
return
}

if(phone.length !== 10){
e.preventDefault()
errorMsg.textContent="Phone number must be 10 digits"
errorMsg.classList.remove("hidden")
return
}

})

</script>

</body>
</html>