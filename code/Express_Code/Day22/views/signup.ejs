<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Signup</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center min-h-screen">

<div class="w-full max-w-sm">

<!-- Signup Card -->

<div class="bg-white border border-gray-300 rounded-lg p-8">

<h1 class="text-3xl font-semibold text-center mb-4 tracking-wide">
Instagram
</h1>

<p class="text-center text-gray-500 text-sm mb-6">
Sign up to see photos and videos from your friends.
</p>

<form action="/signup" method="POST" class="flex flex-col gap-4">

<input
type="text"
name="userName"
placeholder="Username"
class="border border-gray-300 p-2 rounded bg-gray-50 focus:outline-none focus:border-gray-500 focus:ring-1 focus:ring-gray-400"
required
>

<input
type="email"
name="email"
placeholder="Email"
class="border border-gray-300 p-2 rounded bg-gray-50 focus:outline-none focus:border-gray-500 focus:ring-1 focus:ring-gray-400"
required
>

<input
type="password"
name="password"
placeholder="Password"
class="border border-gray-300 p-2 rounded bg-gray-50 focus:outline-none focus:border-gray-500 focus:ring-1 focus:ring-gray-400"
required
>

<button
class="bg-blue-500 text-white py-2 rounded font-semibold hover:bg-blue-600 transition"
>
Sign Up
</button>

</form>

</div>

<!-- Login Card -->

<div class="bg-white border border-gray-300 rounded-lg mt-4 p-4 text-center">
<p class="text-sm">
Have an account?
<a href="/signin" class="text-blue-500 font-semibold">Log in</a>
</p>
</div>

</div>

</body>
</html>